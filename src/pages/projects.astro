---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Autonomous Rover',
    tag: 'Autonomy · Mechanical',
    status: 'Active',
    year: '2024',
    desc: 'A fully autonomous ground vehicle designed for the NASA Robotics Mining Competition. The rover uses LiDAR-based SLAM for navigation and a custom auger system for material excavation.',
    tech: ['ROS2', 'LiDAR', 'SolidWorks', 'Python', 'Custom PCB'],
  },
  {
    title: '6-DOF Robotic Arm',
    tag: 'Manipulation',
    status: 'Active',
    year: '2023',
    desc: 'A desktop-scale robotic arm with sub-millimeter repeatability, built for automated assembly and pick-and-place research. Features a custom inverse kinematics solver.',
    tech: ['ROS2', 'MoveIt', 'Servo Motors', 'C++'],
  },
  {
    title: 'Precision Ag Drone',
    tag: 'Aerial · CV',
    status: 'Active',
    year: '2024',
    desc: 'A quadrotor platform equipped with a multispectral camera for crop health monitoring. Integrates with NDVI analysis pipeline built in-house.',
    tech: ['ArduPilot', 'OpenCV', 'PyTorch', 'Mission Planner'],
  },
  {
    title: 'Line Following Bot',
    tag: 'Beginner Project',
    status: 'Complete',
    year: '2022',
    desc: 'An introductory project for new members. A PID-controlled robot that follows a taped path. Used as a teaching tool each recruitment quarter.',
    tech: ['Arduino', 'PID', 'IR Sensors'],
  },
  {
    title: 'Swarm Robotics Testbed',
    tag: 'Research',
    status: 'Planning',
    year: '2025',
    desc: 'A fleet of small wheeled robots for studying emergent swarm behaviors and distributed consensus algorithms, in collaboration with the CS department.',
    tech: ['ESP32', 'Bluetooth Mesh', 'Python', 'ROS2'],
  },
];
---

<Layout title="Projects" description="Explore robotics projects built by UC Davis Robotics Club members.">

  <section class="page-hero section">
    <div class="container">
      <p class="section-label">What we build</p>
      <h1 class="section-title" style="font-size:clamp(2.5rem,5vw,4rem);">Our Projects</h1>
      <p class="section-body">
        From competition rovers to research platforms — every project is designed, built,
        and tested by students at Davis.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="projects-list">
        {projects.map((p, i) => (
          <div class="project-row">
            <div class="project-img img-placeholder" style="height:260px; border-radius:6px;">[ {p.title} ]</div>
            <div class="project-detail">
              <div class="project-meta">
                <span class="project-tag-text">{p.tag}</span>
                <span class:list={['project-status', p.status === 'Active' ? 'status-active' : p.status === 'Planning' ? 'status-plan' : 'status-done']}>
                  {p.status}
                </span>
              </div>
              <h2 class="proj-title">{p.title}</h2>
              <p class="proj-desc">{p.desc}</p>
              <div class="tech-stack">
                {p.tech.map(t => <span class="tech-tag">{t}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
.projects-list {
  display: flex;
  flex-direction: column;
  gap: 4rem;
}

.project-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  padding-bottom: 4rem;
  border-bottom: 1px solid var(--border);
}

.project-row:last-child { border-bottom: none; }

.project-row:nth-child(even) .project-img { order: 2; }
.project-row:nth-child(even) .project-detail { order: 1; }

.project-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.project-tag-text {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
}

.project-status {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.2em 0.65em;
  border-radius: 999px;
}

.status-active  { background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
.status-done    { background: rgba(100,100,120,0.2); color: var(--text-dim); border: 1px solid var(--border); }
.status-plan    { background: rgba(201,168,76,0.1); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); }

.proj-title {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 800;
  margin-bottom: 1rem;
  color: var(--text);
}

.proj-desc {
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 1.5rem;
}

.tech-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.tech-tag {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  padding: 0.3em 0.75em;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 4px;
  color: var(--text-muted);
}

@media (max-width: 700px) {
  .project-row { grid-template-columns: 1fr; }
  .project-row:nth-child(even) .project-img { order: 0; }
  .project-row:nth-child(even) .project-detail { order: 0; }
}
</style>
